@if (Entity is not null && (ShowId || ShowCreatedDate || ShowUpdatedDate || ShowTermsAgreed))
{
    <h2 class="govuk-heading-l">Details</h2>
    <dl class="govuk-summary-list">
        @if (ShowId)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Id</dt>
                @SummaryValue(_idLabel, nameof(Entity.Id))
            </div>
        }

        @if (ShowCreatedDate)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Created</dt>
                @SummaryValue(_createdDateLabel, nameof(Entity.CreatedUtc))
            </div>
        }

        @if (ShowUpdatedDate)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Updated</dt>
                @SummaryValue(_updatedDateLabel, nameof(Entity.UpdatedUtc))
            </div>
        }

        @if (ShowTermsAgreed)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Terms agreed</dt>
                @SummaryValue(_termsAgreedLabel, nameof(Entity.TermsAgreed))
            </div>
        }
    </dl>
}

<h2 class="govuk-heading-l">Property details</h2>
<dl class="govuk-summary-list">
    @if (ShowIsAddress)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Postal address</dt>
            @SummaryValue(_isAddressLabel, FloodReportCreatePages.Home)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.Home.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> location type</span></a>
            </dd>
        </div>
    }

    @if (ShowLocationDescription && _locationDescriptionPageInfo is not null)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Address or location</dt>
            @SummaryValue(_locationDescriptionLabel, _locationDescriptionPageInfo)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(_locationDescriptionPageInfo.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden">@_locationDescriptionVisuallyHiddenText</span></a>
            </dd>
        </div>
    }

    @if (ShowPropertyType)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Property type</dt>
            @SummaryValue(_propertyTypeLabel, FloodReportCreatePages.PropertyType)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.PropertyType.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> property type</span></a>
            </dd>
        </div>
    }

    @if (ShowFloodedAreas)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Areas flooded</dt>
            @SummaryValues(_floodedAreaLabels, FloodReportCreatePages.FloodAreas)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodAreas.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> which areas of the property were flooded</span></a>
            </dd>
        </div>
    }

    @if (ShowIsUninhabitable)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Evacuation</dt>
            @SummaryValue(_isUninhabitableLabel, FloodReportCreatePages.FloodAreas)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodAreas.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> whether you evactuated the property</span></a>
            </dd>
        </div>
    }

    @if (ShowTemporaryLocationDescription)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Temporary address</dt>
            @SummaryValue(_temporaryLocationDescriptionLabel, FloodReportCreatePages.TemporaryAddress)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.TemporaryAddress.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> temporary address</span></a>
            </dd>
        </div>
    }
</dl>

<h2 class="govuk-heading-l">Flood details</h2>
<dl class="govuk-summary-list">
    @if (ShowImpactStart)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">The flooding started on</dt>
            @SummaryValue(_impactStartLabel, FloodReportCreatePages.FloodStarted)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodStarted.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> when the flooding started</span></a>
            </dd>
        </div>
    }

    @if (ShowIsOnGoing)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Still flooding</dt>
            @SummaryValue(_isOnGoingLabel, FloodReportCreatePages.FloodStarted)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodStarted.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> if you are still flooded</span></a>
            </dd>
        </div>
    }

    @if (ShowFloodingLasted)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Flooding lasted</dt>
            @SummaryValue(_floodingLastedLabel, FloodReportCreatePages.FloodDuration)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodDuration.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> how long the flooding lasted</span></a>
            </dd>
        </div>
    }

    @if (ShowVulnerablePeople)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Vulnerable people affected</dt>
            @SummaryValue(_vulnerablePeopleLabel, FloodReportCreatePages.Vulnerability)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.Vulnerability.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> the number of vulnerable people reported</span></a>
            </dd>
        </div>
    }

    @if (ShowSources)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Flood source</dt>
            @SummaryValues(_sourceLabels, FloodReportCreatePages.FloodSource)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodSource.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> the source of the flooding</span></a>
            </dd>
        </div>
    }

    @if (ShowSecondarySources)
    {
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key govuk-!-width-one-quarter govuk-!-padding-right-1">Runoff source</dt>
            @SummaryValues(_secondarySourceLabels, FloodReportCreatePages.FloodSecondarySource)
            <dd class="govuk-summary-list__actions">
                <a draggable="false" data-prevent-double-click="true" href="@(FloodReportCreatePages.FloodSecondarySource.Url)?fromSummary=true" class="govuk-link">Change<span class="govuk-visually-hidden"> the source of runoff</span></a>
            </dd>
        </div>
    }
</dl>

@code {
    private RenderFragment SummaryValue(string? label, PageInfo pageInfo)
    {
        if (label is null)
        {
            return @<dd class="govuk-summary-list__value govuk-error-message">Unknown</dd>;
        }

        var hasFailures = _validationFailures.Exists(failure => failure.CustomState.Equals(pageInfo));
        return hasFailures
            ? @<dd class="govuk-summary-list__value govuk-error-message">missing information</dd>
            : @<dd class="govuk-summary-list__value">@label</dd>;
    }

    private RenderFragment SummaryValue(string? label, string propertyName)
    {
        if (label is null)
        {
            return @<dd class="govuk-summary-list__value govuk-error-message">Unknown</dd>;
        }

        var hasFailures = _validationFailures.Exists(failure => failure.PropertyName.Equals(propertyName));
        return hasFailures
            ? @<dd class="govuk-summary-list__value govuk-error-message">missing information</dd>
            : @<dd class="govuk-summary-list__value">@label</dd>;
    }

    private RenderFragment SummaryValues(string[] labels, PageInfo pageInfo)
    {
        if (labels.Length == 0)
        {
            return @<dd class="govuk-summary-list__value govuk-error-message">Unknown</dd>;
        }

        var hasFailures = _validationFailures.Exists(failure => failure.CustomState.Equals(pageInfo));
        return hasFailures
            ? @<dd class="govuk-summary-list__value govuk-error-message">missing information</dd>
            : @<dd class="govuk-summary-list__value">
            <ul class="govuk-list">
                @foreach (var label in labels)
                {
                    <li>@label</li>
                }
            </ul>
        </dd>;
    }
}