@page "/floodreport/create"

<PageTitle>@Title</PageTitle>

<GdsBreadcrumbs Items="Breadcrumbs" />

<EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit" FormName="CreateFloodReport">
    <FluentValidationValidator />
    <GdsErrorSummary />

    @* <GdsSpinner Show="_isLoading" ShowMessage="true" /> *@

    <h2>TESTING</h2>
    <p>Rendering: @RendererInfo.Name</p>
    <p role="status">Cache key: @CacheKey</p>
    <p role="status">Cache key 2: @CacheKey2</p>

    <GdsFormGroup For="() => Model.IsAddress" Id="location-or-address">
        <InputRadioGroup @bind-Value="Model.IsAddress">
            <GdsFieldsetGroup>
                <Heading>
                    <h1 class="govuk-fieldset__heading">Are you reporting an address or property?</h1>
                </Heading>
                <Content>
                    <GdsHint>i.e. location with a Royal Mail postal address rather than a structure or land.</GdsHint>
                    <GdsErrorMessage />
                    <GdsRadios Options="_isAddressOptions" />
                </Content>
            </GdsFieldsetGroup>
        </InputRadioGroup>
    </GdsFormGroup>

    <p><button type="submit" data-prevent-double-click="true" class="govuk-button" data-module="govuk-button">Continue</button></p>
</EditForm>